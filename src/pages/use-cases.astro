---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Topologies d'Architecture | R.A.I.S.E.";
const description =
  "Blueprints d'intégration. Déployez le framework Open Core R.A.I.S.E. pour sécuriser vos environnements d'ingénierie critique.";

// LES BLUEPRINTS (DONNÉES D'INFRASTRUCTURE AVEC KPIs)
const templates = [
  {
    id: 'arch-mbse',
    category: 'AÉROSPATIAL (MBSE)',
    title: 'Génération de Code Certifiable',
    icon: '✈️',
    description:
      "Automatisation de l'ingénierie dirigée par les modèles (SysML v2 / Arcadia). Transformation garantie sans perte d'intégrité vers du code source de production.",
    modules: [
      { name: 'model_engine', role: 'Abstraction SysML', color: 'text-rust' },
      { name: 'code_generator', role: 'AST Builder', color: 'text-blue-500' },
      { name: 'traceability', role: 'Audit DO-178C', color: 'text-slate-400' },
    ],
    features: ['Tolérance Zéro (AST pur)', 'Handles stricts'],
    popularity: 'Standard DO-178C',
    kpis: [
      { label: 'Test en Prod', val: '0' },
      { label: 'Traçabilité', val: '100%' },
      { label: 'Génération', val: '< 2s' },
    ],
  },
  {
    id: 'infra-devsecops',
    category: 'DÉFENSE & SÉCURITÉ',
    title: 'Pipeline DevSecOps Air-Gap',
    icon: '🛡️',
    description:
      "Déploiement d'une chaîne CI/CD 100% déconnectée. Orchestration locale des builds, tests et livraisons sans aucune dépendance aux API Cloud.",
    modules: [
      { name: 'kernel', role: 'Orchestrateur Async', color: 'text-rust' },
      { name: 'rules_engine', role: 'Validation Statique', color: 'text-purple-500' },
      { name: 'raise-cli', role: 'Pilote Contextuel', color: 'text-slate-400' },
    ],
    features: ['Fallback CLI auto', 'Zéro appel WAN'],
    popularity: 'Recommandé OIV',
    kpis: [
      { label: 'Requêtes Sort.', val: '0 bit' },
      { label: 'Disponibilité', val: '99.9%' },
      { label: 'Latence', val: '< 50ms' },
    ],
  },
  {
    id: 'ind-twin',
    category: 'INDUSTRIE 4.0',
    title: 'Jumeau Numérique Déterministe',
    icon: '🏭',
    description:
      "Gestion de l'état d'installations critiques (RAMI 4.0). Moteur de base de données locale interdisant les identifiants instables (UUID) au profit de handles explicites.",
    modules: [
      { name: 'json_db', role: 'Stockage ACID', color: 'text-rust' },
      { name: 'spatial_engine', role: 'Topologie', color: 'text-orange-500' },
      { name: 'plugins', role: 'Isolation Wasm', color: 'text-slate-400' },
    ],
    features: ['Intégrité par Handles', 'Schémas Explicites'],
    popularity: 'Conforme RAMI',
    kpis: [
      { label: 'Fuite UUID', val: '0' },
      { label: 'Transactions', val: '> 10k/s' },
      { label: 'Isolation', val: 'Wasm' },
    ],
  },
  {
    id: 'edge-tactical',
    category: 'SYSTÈMES EMBARQUÉS',
    title: 'Hyperviseur Edge Tactique',
    icon: '📡',
    description:
      "Infrastructure allégée pour unités mobiles. Exécution de logique métier isolée dans des bacs à sable WebAssembly avec empreinte mémoire minimale.",
    modules: [
      { name: 'raise-edge', role: 'Runtime Allégé', color: 'text-rust' },
      { name: 'plugins', role: 'Wasm Sandbox', color: 'text-green-600' },
      { name: 'kernel', role: 'Micro-Orchestrateur', color: 'text-slate-400' },
    ],
    features: ['Mémoire No-GC', 'Isolation totale'],
    popularity: '',
    kpis: [
      { label: 'Cold Start', val: '< 10ms' },
      { label: 'Empreinte', val: '< 15Mo' },
      { label: 'Crash Rate', val: '0%' },
    ],
  }
];
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <Header />

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <div class="text-center mb-12 animate-fade-in">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded border border-blue-200 bg-blue-50 text-blue-900 text-[10px] font-mono uppercase tracking-widest mb-6"
        >
          <span class="text-blue-600 animate-pulse">●</span> Standards d'Implémentation | Framework v0.3.0
        </div>

        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-6">
          Topologies <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-rust">Architecturales</span>
        </h1>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto mb-10">
          Ne réinventez pas l'infrastructure critique. Déployez nos <strong>Blueprints certifiés</strong> pour résoudre vos défis d'ingénierie de pointe (MBSE, DevSecOps, Edge).
        </p>

        <div
          class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-xl max-w-3xl mx-auto text-left flex gap-4 shadow-sm"
        >
          <div class="text-2xl pt-1">🏗️</div>
          <div>
            <h3 class="font-bold text-blue-900 text-sm uppercase tracking-wide mb-1">
              Architecture Open Core
            </h3>
            <p class="text-sm text-blue-800/80 leading-snug">
              Ces modèles de référence illustrent l'assemblage des modules du noyau <strong>raise-core</strong>. Ils fournissent le châssis sécurisé (Air-Gap) prêt à accueillir vos logiques métiers propriétaires via l'interface des plugins Wasm.
            </p>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
        {
          templates.map((tpl) => (
            <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group relative overflow-hidden flex flex-col">
              {/* Badge Popularité */}
              {tpl.popularity && (
                <div class="absolute top-0 right-0 bg-rust text-white text-[10px] font-bold px-3 py-1 rounded-bl-xl uppercase tracking-widest shadow-sm z-10">
                  {tpl.popularity}
                </div>
              )}

              <div class="flex items-start justify-between mb-6">
                <div class="flex items-center gap-4">
                  <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center text-4xl border border-slate-100 shadow-inner group-hover:scale-110 transition-transform">
                    {tpl.icon}
                  </div>
                  <div>
                    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">
                      {tpl.category}
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 leading-tight">{tpl.title}</h3>
                  </div>
                </div>
              </div>

              <p class="text-slate-600 mb-6 h-16 leading-relaxed text-xs lg:text-sm line-clamp-3">
                {tpl.description}
              </p>

              {/* BLOC KPIs INFRASTRUCTURE */}
              <div class="grid grid-cols-3 gap-2 mb-6 border-y border-slate-100 py-4">
                {tpl.kpis.map((kpi) => (
                  <div class="text-center">
                    <div class="text-lg font-black text-slate-800">{kpi.val}</div>
                    <div class="text-[9px] uppercase text-slate-400 font-bold tracking-wide">
                      {kpi.label}
                    </div>
                  </div>
                ))}
              </div>

              {/* Visualisation de la Stack (Crates utilisés) */}
              <div class="bg-slate-50 rounded-xl p-5 border border-slate-100 mb-8 grow">
                <div class="text-xs font-bold text-slate-400 uppercase mb-3 flex justify-between">
                  <span>Modules Sollicités (Crates)</span>
                  <span>Rôle</span>
                </div>
                <div class="space-y-3">
                  {tpl.modules.map((m) => (
                    <div class="flex items-center justify-between border-b border-slate-200/50 pb-2 last:border-0 last:pb-0">
                      <span class={`text-xs font-mono font-bold ${m.color}`}>::{m.name}</span>
                      <span class="text-xs text-slate-500">{m.role}</span>
                    </div>
                  ))}
                </div>
                <div class="mt-4 pt-3 border-t border-slate-200/50 flex gap-2">
                  {tpl.features.map((f) => (
                     <span class="text-[9px] bg-slate-200 text-slate-600 px-2 py-1 rounded font-bold uppercase">{f}</span>
                  ))}
                </div>
              </div>

              {/* Footer Carte */}
              <div class="flex items-center justify-between mt-auto">
                <div class="flex items-center gap-2 text-xs text-slate-500">
                  <span class="w-2 h-2 rounded-full bg-green-500" />
                  <strong>Ready</strong> pour intégration IP
                </div>
                <button class="bg-slate-900 hover:bg-rust text-white text-xs font-bold py-2 px-4 rounded-lg transition-colors flex items-center gap-2 group">
                  <span>Voir Spécification</span>
                  <span class="group-hover:translate-x-1 transition-transform">→</span>
                </button>
              </div>
            </div>
          ))
        }
      </div>

      <div class="bg-slate-900 rounded-[3rem] p-12 text-center text-white relative overflow-hidden">
        <div
          class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"
        >
        </div>
        <div class="relative z-10">
          <h2 class="text-3xl font-bold mb-4">Besoin d'une topologie spécifique ?</h2>
          <p class="text-slate-300 mb-8 max-w-2xl mx-auto">
            L'architecture modulaire de R.A.I.S.E. permet d'isoler n'importe quelle chaîne de valeur. Nos architectes peuvent concevoir votre Blueprint sur-mesure en 48h.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-full hover:bg-slate-100 transition-colors"
          >
            Demander une Étude Architecturale
          </a>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>