---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "R.A.I.S.E. | L'Infrastructure d'Ingénierie Critique";
const description =
  "Framework Open Core Local-First pour l'industrialisation des méthodes formelles, la modélisation MBSE 2.0 et l'automatisation sécurisée des chaînes DevSecOps.";
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "R.A.I.S.E. Open Core",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Linux, Rust environment",
        "description": "Châssis d'infrastructure Local-First et Air-Gap pour l'ingénierie système dirigée par les modèles et l'automatisation DevSecOps.",
        "author": {
          "@type": "Organization",
          "name": "Condorcet Continuum"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR"
        }
      }
    </script>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <Header />

    <main>
      <section class="relative pt-20 pb-32 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded border border-blue-200 bg-blue-50 text-blue-900 text-[10px] font-mono uppercase tracking-widest mb-6"
          >
            <span class="text-blue-600 animate-pulse">●</span> Standard d'Infrastructure MBSE & DevSecOps | Open Core v0.3.0
          </div>

          <h1 class="text-5xl md:text-7xl font-extrabold text-slate-900 mb-8 tracking-tight">
            Industrialisez l'Ingénierie Critique.<br />
            <span class="text-transparent bg-clip-text bg-linear-to-r from-rust to-orange-500"
              >Passez à l'Engagement de Performance.</span
            >
          </h1>

          <p class="text-xl text-slate-600 max-w-3xl mx-auto mb-12 leading-relaxed">
            R.A.I.S.E. fournit le premier <strong>châssis technologique immuable</strong> qui automatise vos chaînes de valeur industrielles. Conçu en Rust pour le paradigme Local-First, il sécurise l'exécution de vos processus en zone étanche (Air-Gap).
          </p>

          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a
              href="https://github.com/Condorcet-Continuum/raise"
              target="_blank"
              class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-slate-900 rounded-full hover:bg-rust transition-all shadow-lg hover:shadow-xl group"
            >
              <span>Déployer le Core (GitHub)</span>
              <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <a
              href="/architecture"
              class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-slate-600 bg-white border border-slate-200 rounded-full hover:bg-slate-50 transition-all"
            >
              Explorer l'Architecture
            </a>
          </div>
        </div>

        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-slate-200/50 rounded-full blur-[100px] -z-10 pointer-events-none opacity-50"
        >
        </div>
      </section>

      <section class="py-24 bg-white border-y border-slate-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="group">
              <div
                class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform duration-300"
              >
                📐
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-3">Ingénierie Dirigée par les Modèles</h3>
              <p class="text-slate-500 leading-relaxed text-sm">
                Accélérez la transformation de votre business model de la régie vers la capacité. Alignement natif avec les standards MBSE 2.0, SysML v2 et la méthode Arcadia pour standardiser l'excellence technique des forfaits.
              </p>
            </div>

            <div class="group">
              <div
                class="w-16 h-16 bg-orange-50 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform duration-300"
              >
                🔗
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-3">Intégrité Native par Handles</h3>
              <p class="text-slate-500 leading-relaxed text-sm">
                Élimination définitive des identifiants internes instables et des fuites de UUIDs. Le moteur de persistance locale valide les relations de manière déterministe via des handles explicites et des arguments de schémas stricts.
              </p>
            </div>

            <div class="group">
              <div
                class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform duration-300"
              >
                🛡️
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-3">Le Dogme de la Forteresse</h3>
              <p class="text-slate-500 leading-relaxed text-sm">
                Zéro compromis sur la sécurité mémoire. Runtime écrit en Rust, extensibilité isolée par bac à sable (WebAssembly) et politique de production pure : aucune condition de test n'est tolérée dans le code livré.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-24 bg-slate-900 overflow-hidden relative">
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-rust/5 rounded-full blur-[120px] pointer-events-none"
        >
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">
              L'Infrastructure de <span class="text-rust">Confiance</span> Air-Gap
            </h2>
            <p class="text-xl text-slate-400 max-w-3xl mx-auto">
              Ne dépendez plus d'infrastructures Cloud tierces pour vos données d'ingénierie sensibles. R.A.I.S.E. s'exécute en local et protège votre capital intellectuel.
            </p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="space-y-10">
              <div class="flex gap-6 group">
                <div
                  class="w-12 h-12 rounded-xl bg-slate-800 group-hover:bg-rust transition-colors flex items-center justify-center text-2xl border border-slate-700 shrink-0 shadow-lg"
                >
                  ⚙️
                </div>
                <div>
                  <h3 class="text-xl font-bold text-white mb-2">Automatisation DevSecOps</h3>
                  <p class="text-slate-400 leading-relaxed text-sm">
                    Raccourcissez le cycle de création de valeur et éradiquez le boilerplate. Le moteur orchestre les pipelines complexes de transformation de modèles et de génération de code certifiable.
                  </p>
                </div>
              </div>

              <div class="flex gap-6 group">
                <div
                  class="w-12 h-12 rounded-xl bg-slate-800 group-hover:bg-rust transition-colors flex items-center justify-center text-2xl border border-slate-700 shrink-0 shadow-lg"
                >
                  🧩
                </div>
                <div>
                  <h3 class="text-xl font-bold text-white mb-2">Contexte & Session Intelligente</h3>
                  <p class="text-slate-400 leading-relaxed text-sm">
                    L'outil en ligne de commande <code class="text-rust">raise-cli</code> s'adapte dynamiquement à son environnement. Si les arguments de domaine ou de base de données ne sont pas spécifiés, il se rabat automatiquement sur le contexte de la session active.
                  </p>
                </div>
              </div>

              <div class="flex gap-6 group">
                <div
                  class="w-12 h-12 rounded-xl bg-slate-800 group-hover:bg-rust transition-colors flex items-center justify-center text-2xl border border-slate-700 shrink-0 shadow-lg"
                >
                  🔒
                </div>
                <div>
                  <h3 class="text-xl font-bold text-white mb-2">Silo d'Abstraction des Secrets</h3>
                  <p class="text-slate-400 leading-relaxed text-sm">
                    L'architecture Open Core expose des abstractions pures (Traits et Stubs d'API). Vos moteurs métiers spécialisés ou vos algorithmes d'optimisation propriétaires restent cloisonnés dans votre infrastructure privée, à l'abri des dépôts publics.
                  </p>
                </div>
              </div>
            </div>

            <div
              class="bg-black rounded-2xl border border-slate-800 shadow-2xl p-6 font-mono text-xs relative overflow-hidden group hover:border-rust/30 transition-colors duration-500"
            >
              <div class="flex justify-between items-center mb-4 border-b border-slate-800 pb-4">
                <div class="flex gap-2">
                  <div class="w-3 h-3 rounded-full bg-slate-700"></div>
                  <div class="w-3 h-3 rounded-full bg-slate-700"></div>
                </div>
                <div class="text-slate-500 font-bold tracking-widest uppercase">
                  RAISE CORE RUNTIME (Air-Gap)
                </div>
              </div>

              <div class="space-y-4 h-[400px] overflow-hidden relative">
                <div
                  class="absolute inset-x-0 bottom-0 h-20 bg-linear-to-t from-black to-transparent z-10"
                >
                </div>

                <div class="opacity-40 flex gap-4 text-slate-500">
                  <span class="w-24">14:02:10.012</span>
                  <span class="text-blue-500">INFO</span>
                  <span>zair@condorcet:~$ raise-cli deploy --sync</span>
                </div>

                <div class="opacity-60 flex gap-4 text-slate-400">
                  <span class="w-24">14:02:10.050</span>
                  <span class="text-blue-400">KERNEL</span>
                  <span>Initializing asynchronous micro-kernel...</span>
                </div>

                <div class="opacity-80 flex gap-4 text-slate-400">
                  <span class="w-24">14:02:10.120</span>
                  <span class="text-blue-400">DATA_AGNT</span>
                  <span>Validating data schema: 100% explicit arguments enforced.</span>
                </div>

                <div class="bg-slate-900/50 p-3 rounded border-l-2 border-rust flex flex-col gap-2 shadow-inner">
                  <div class="flex gap-4 text-slate-300">
                    <span class="w-24 font-bold text-white">14:02:10.298</span>
                    <span class="text-rust font-bold">INTEGRITY</span>
                    <span>Database check passed.</span>
                  </div>
                  <div class="pl-28 text-slate-500">
                    > Storage: <span class="text-orange-400">json_db (Active)</span><br />
                    > Mode: <span class="text-blue-400">Handle-based resolution (Zero UUID leakage)</span><br />
                    > Production Audit: <span class="text-green-500 font-bold">0 test conditions found in runtime AST</span>
                  </div>
                </div>

                <div class="flex gap-4 text-slate-400">
                  <span class="w-24">14:02:10.410</span>
                  <span class="text-orange-500">CONTEXT</span>
                  <span>Missing specific flag --domain. Smart fallback active.</span>
                </div>

                <div class="flex gap-4 text-slate-300 animate-pulse">
                  <span class="w-24">14:02:10.412</span>
                  <span class="text-green-500">SUCCESS</span>
                  <span>Target bound to current_domain and current_db of active session.</span>
                </div>

                <div class="flex gap-4 text-slate-500">
                  <span class="w-24">14:02:10.500</span>
                  <span class="text-slate-600">DEPLOY</span>
                  <span>Standalone single binary sealed to standalone environment.</span>
                </div>
              </div>

              <div
                class="absolute bottom-0 left-0 w-full bg-slate-900/90 backdrop-blur border-t border-slate-800 p-3 flex justify-between items-center text-[10px] text-slate-400"
              >
                <div class="flex items-center gap-2">
                  <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                  Châssis Vérifié & Stable
                </div>
                <div>Isolation: <span class="text-white">WebAssembly Sandbox</span></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-20 text-center">
        <div class="max-w-4xl mx-auto px-4">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Prêt à sécuriser vos architectures complexes ?</h2>
          <p class="text-lg text-slate-600 mb-10">
            Le châssis d'infrastructure Open Core de R.A.I.S.E. est auditable, documenté et prêt pour la production. Passez de l'expérimentation fragile à la maîtrise totale de vos environnements critiques.
          </p>
          <a
            href="/pilot"
            class="inline-flex items-center justify-center px-10 py-5 text-lg font-bold text-white bg-rust rounded-full hover:bg-orange-600 transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1"
          >
            Devenir Partenaire Pilote
          </a>
          <p class="mt-4 text-sm text-slate-400">Alignement méthodologique complet RAMI 4.0 & MBSE 2.0</p>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>